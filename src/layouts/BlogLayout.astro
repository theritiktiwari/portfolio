---
import type { BlogCardProps } from "@/components/blog-card";
import RelatedPosts from "@/components/related-posts.astro";
import { SeriesNav, type SeriesPost } from "@/components/series-nav";
import TOC from "@/components/toc.astro";
import CopyCode from "@/components/ui/copy-code.astro";
import { MaskedIcon } from "@/components/ui/masked-icon";
import { TagList } from "@/components/ui/tag-list";
import { socialIcons } from "@/constants/images";
import Layout from "@/layouts/Layout.astro";
import { formatDate } from "@/lib/utils";
import type { MarkdownHeading } from "astro";
import { Image } from "astro:assets";
import { ArrowLeft, Calendar, Clock, Layers, MessageSquareWarning, User } from "lucide-react";

interface Props {
	title: string;
	description: string;
	pubDate: Date;
	heroImage?: ImageMetadata;
	author?: string;
	tags?: string[];
	readingTime?: number;
	headings?: MarkdownHeading[];
	series?: { name: string; part: number };
	seriesPosts?: SeriesPost[];
	relatedPosts?: BlogCardProps[];
	editUrl?: string;
	issueUrl?: string;
}

const {
	title,
	description,
	pubDate,
	heroImage,
	author,
	tags = [],
	readingTime = 1,
	headings = [],
	series,
	seriesPosts = [],
	relatedPosts = [],
	editUrl,
	issueUrl,
} = Astro.props;

const ogImageUrl = heroImage?.src ?? "/og-image.png";
const publishedIso = pubDate.toISOString();
---

<Layout title={`${title} | Ritik Tiwari`} description={description} ogImage={ogImageUrl}>
	<!-- Article-specific meta in the head slot -->
	<Fragment slot="head">
		<meta property="og:type" content="article" />
		<meta property="article:published_time" content={publishedIso} />
		{tags.map((tag) => <meta property="article:tag" content={tag} />)}
		<link
			rel="alternate"
			type="application/rss+xml"
			title="Ritik Tiwari — Blog"
			href="/rss.xml"
		/>
	</Fragment>

	<div class="-mt-12 md:-mt-16 lg:mt-0 mx-auto">
		<nav
			class="flex items-center gap-5 bg-background/75 sticky top-0 z-20 mx-auto mb-4 w-full py-5 backdrop-blur"
		>
			<a
				href="/blog"
				class="text-primary font-semibold text-sm flex items-center gap-1.5 transition-colors"
			>
				<ArrowLeft className="size-3.5" />
				All posts
			</a>
		</nav>

		<main class="lg:grid lg:grid-cols-[1fr_220px] lg:gap-12">
			<article class="space-y-8">
				{
					heroImage && (
						<div class="overflow-hidden rounded-2xl">
							<Image
								src={heroImage}
								alt={title}
								class="h-auto w-full object-cover"
								loading="eager"
							/>
						</div>
					)
				}

				<header id="content" class="">
					<h1
						class="text-foreground mb-4 text-3xl font-bold leading-tight tracking-tight sm:text-4xl"
					>
						{title}
					</h1>

					{tags.length > 0 && <TagList items={tags} label="Tags" className="mb-3 gap-2" />}

					<div class="text-muted-foreground flex flex-wrap items-center gap-4 text-sm">
						<span class="flex items-center gap-1.5">
							<Calendar className="size-3.5" />
							<time datetime={publishedIso}>
								{formatDate({ date: pubDate, options: { day: "numeric" } })}
							</time>
						</span>

						<span class="flex items-center gap-1.5">
							<Clock className="size-3.5" />
							{readingTime} min read
						</span>

						{series && (
							<span class="flex items-center gap-1.5">
								<Layers className="size-3.5" />
								{series.name} · Part {series.part}{seriesPosts.length > 0 && ` of ${seriesPosts.length}`}
							</span>
						)}

						{author && (
							<span class="flex items-center gap-1.5">
								<User className="size-3.5" />
								{author}
							</span>
						)}
					</div>
				</header>

				<div class="prose light:prose-neutral prose-invert max-w-none">
					<slot />
					<CopyCode />
				</div>

				<hr>

				{
					(editUrl || issueUrl) && (
						<div class="border-border flex flex-wrap items-center justify-between gap-4 border-b pb-8 text-sm">
							{editUrl && (
								<a
									href={editUrl}
									target="_blank"
									rel="noopener noreferrer"
									class="text-muted-foreground hover:text-primary font-semibold flex items-center gap-1.5 transition-colors"
								>
									<MaskedIcon
										src={socialIcons.github.src}
										maskSize={socialIcons.github.maskSize}
										className="size-3.5 shrink-0"
									/>
									Edit on GitHub
								</a>
							)}

							{issueUrl && (
								<a
									href={issueUrl}
									target="_blank"
									rel="noopener noreferrer"
									class="text-muted-foreground hover:text-primary font-semibold flex items-center gap-1.5 transition-colors"
								>
									<MessageSquareWarning className="size-3.5 shrink-0" />
									Report a mistake
								</a>
							)}
						</div>
					)
				}

				{
					series && seriesPosts.length > 0 && (
						<div class="">
							<SeriesNav
								seriesName={series.name}
								currentPart={series.part}
								posts={seriesPosts}
							/>
						</div>
					)
				}

				<RelatedPosts posts={relatedPosts} />
			</article>

			<aside class="hidden lg:block">
				<div class="sticky top-18">
					<TOC headings={headings} />
				</div>
			</aside>
		</main>
	</div>
</Layout>
