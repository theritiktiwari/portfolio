---
import { Button } from "@/components/ui/button";
import Layout from "@/layouts/Layout.astro";
import { ArrowLeft, ArrowUpRight, FileQuestion } from "lucide-react";
---

<Layout
	title="404 — Page Not Found | Ritik Tiwari"
	description="The page you're looking for doesn't exist."
>
	<div
		id="content"
		class="flex min-h-screen flex-col items-center justify-center gap-10 text-center"
	>
		<div class="space-y-5">
			<FileQuestion className="text-destructive/30 size-20 stroke-1" />
			<p class="text-destructive text-xs font-semibold tracking-widest uppercase">
				Error 404
			</p>
		</div>

		<div class="space-y-4">
			<h1 class="text-foreground text-4xl font-bold tracking-tight sm:text-5xl">
				Page not found
			</h1>
			<p class="text-muted-foreground mx-auto max-w-sm text-base leading-relaxed">
				Sorry, the page you're looking for doesn't exist or has been moved.
			</p>
		</div>

		<div class="flex items-center gap-4">
			<Button variant="ghost">
				<ArrowLeft className="size-4 shrink-0" />
				<a href="/">Go home</a>
			</Button>
			<Button variant="outline">
				<a href="/blog">Read the blog</a>
				<ArrowUpRight className="size-4 shrink-0" />
			</Button>
		</div>
	</div>
</Layout>
